# Backend (Netlify functions + scheduled jobs)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_ENVIRONMENT=production
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
BOOKING_WEBSITE_DOMAIN=snpdetailing.ca
# Optional: path-style short links (default) → https://snpdetailing.ca/r/{code}/m
# Set BOOKING_URL_STYLE=query for https://snpdetailing.ca/book?r={code}&s=m
# BOOKING_URL_PATH=r
# BOOKING_WEBSITE_KEEP_WWW=true

# Optional: exact public URL Twilio posts to (use if signature validation fails behind a proxy)
# TWILIO_WEBHOOK_URL=https://your-site.netlify.app/.netlify/functions/twilio-inbound-sms
# Set to false only for local testing without Twilio signature validation
# TWILIO_VALIDATE_SIGNATURE=false

# Production reminder SMS (scheduled + Send now). Keep false until you are ready to text clients.
SMS_PRODUCTION_SENDS_ENABLED=false

# Optional: when production is enabled, set true to redirect ALL sends to SMS_TEST_PHONE_NUMBER instead of clients
SMS_TEST_MODE=false
SMS_TEST_PHONE_NUMBER=+15149841671
