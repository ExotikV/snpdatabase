NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DASHBOARD_PASSWORD=change-me-before-going-live
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
BOOKING_WEBSITE_DOMAIN=www.snpdetailing.ca

# Backend nightly sync (Netlify scheduled function + /api/cron/daily-sync)
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_ENVIRONMENT=production
CRON_SECRET=generate-a-long-random-string

# Optional alias — backend scripts read SUPABASE_URL; dashboard maps from NEXT_PUBLIC_* if unset
# SUPABASE_URL=https://your-project.supabase.co
